# Supabase URL (Supabase dashboard -> Settings -> API -> Project URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase Service Role Key (Supabase dashboard -> Settings -> API -> service_role)
# CRITICAL: Use the service_role key, NOT the anon key, as the backend needs to bypass RLS policies
SUPABASE_KEY=your-service-role-key-jwt

# Groq API Key for AI Reasoning & AI Suggested Remediation (https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_api_key

# 64-character hex string used as pepper for HMAC-SHA256 hashing of secrets and alert signatures
# Generate one with: openssl rand -hex 32
HMAC_SECRET_KEY=your-hmac-secret-hex-key

# Fernet encryption key used to encrypt code snippet data before saving to DB
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-base64-key

# GitHub Personal Access Token (classic token with no scopes required, used to bypass API rate limits)
# Get at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token

# Optional: SMTP email alerts configurations for CRITICAL severity findings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# Use an App Password (not your primary password)
SMTP_PASSWORD=your-smtp-app-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
ALERT_EMAIL_FROM=your-email@gmail.com
# Comma-separated list of recipients for alerts
ALERT_EMAIL_TO=recipient1@gmail.com,recipient2@gmail.com

# Comma-separated list of allowed frontend origins for CORS configuration
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
